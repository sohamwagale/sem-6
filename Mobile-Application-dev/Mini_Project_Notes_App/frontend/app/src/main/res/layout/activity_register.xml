<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/gradient_background"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="@dimen/spacing_lg">

        <!-- Back Button -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/ivBack"
                android:layout_width="@dimen/icon_size_lg"
                android:layout_height="@dimen/icon_size_lg"
                android:src="@drawable/ic_back"
                android:contentDescription="@string/content_description_back"
                android:padding="@dimen/spacing_xs" />
        </LinearLayout>

        <!-- Spacer -->
        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <!-- Title -->
        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/register_title"
            android:textColor="@color/text_primary"
            android:textSize="@dimen/text_xxl"
            android:textStyle="bold"
            android:layout_marginBottom="@dimen/spacing_sm" />

        <!-- Subtitle -->
        <TextView
            android:id="@+id/tvSubtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/register_subtitle"
            android:textColor="@color/text_secondary"
            android:textSize="@dimen/text_sm"
            android:layout_marginBottom="@dimen/spacing_xl" />

        <!-- Name Input -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="@dimen/input_height"
            android:background="@drawable/rounded_input"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="@dimen/spacing_md"
            android:layout_marginBottom="@dimen/spacing_md">

            <ImageView
                android:layout_width="@dimen/icon_size_sm"
                android:layout_height="@dimen/icon_size_sm"
                android:src="@drawable/ic_person"
                android:contentDescription="@null"
                android:layout_marginEnd="@dimen/spacing_sm" />

            <EditText
                android:id="@+id/etName"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="@null"
                android:hint="@string/hint_name"
                android:inputType="textPersonName"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_hint"
                android:textSize="@dimen/text_md"
                android:importantForAutofill="no" />
        </LinearLayout>

        <!-- Email Input -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="@dimen/input_height"
            android:background="@drawable/rounded_input"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="@dimen/spacing_md"
            android:layout_marginBottom="@dimen/spacing_md">

            <ImageView
                android:layout_width="@dimen/icon_size_sm"
                android:layout_height="@dimen/icon_size_sm"
                android:src="@drawable/ic_email"
                android:contentDescription="@null"
                android:layout_marginEnd="@dimen/spacing_sm" />

            <EditText
                android:id="@+id/etEmail"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="@null"
                android:hint="@string/hint_email"
                android:inputType="textEmailAddress"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_hint"
                android:textSize="@dimen/text_md"
                android:importantForAutofill="no" />
        </LinearLayout>

        <!-- Password Input -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="@dimen/input_height"
            android:background="@drawable/rounded_input"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="@dimen/spacing_md"
            android:layout_marginBottom="@dimen/spacing_md">

            <ImageView
                android:layout_width="@dimen/icon_size_sm"
                android:layout_height="@dimen/icon_size_sm"
                android:src="@drawable/ic_lock"
                android:contentDescription="@null"
                android:layout_marginEnd="@dimen/spacing_sm" />

            <EditText
                android:id="@+id/etPassword"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="@null"
                android:hint="@string/hint_password"
                android:inputType="textPassword"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_hint"
                android:textSize="@dimen/text_md"
                android:importantForAutofill="no" />
        </LinearLayout>

        <!-- Confirm Password Input -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="@dimen/input_height"
            android:background="@drawable/rounded_input"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="@dimen/spacing_md"
            android:layout_marginBottom="@dimen/spacing_lg">

            <ImageView
                android:layout_width="@dimen/icon_size_sm"
                android:layout_height="@dimen/icon_size_sm"
                android:src="@drawable/ic_lock"
                android:contentDescription="@null"
                android:layout_marginEnd="@dimen/spacing_sm" />

            <EditText
                android:id="@+id/etConfirmPassword"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="@null"
                android:hint="@string/hint_confirm_password"
                android:inputType="textPassword"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_hint"
                android:textSize="@dimen/text_md"
                android:importantForAutofill="no" />
        </LinearLayout>

        <!-- Error Text -->
        <TextView
            android:id="@+id/tvError"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/error_red"
            android:textSize="@dimen/text_sm"
            android:visibility="gone"
            android:layout_marginBottom="@dimen/spacing_md" />

        <!-- Register Button -->
        <Button
            android:id="@+id/btnRegister"
            android:layout_width="match_parent"
            android:layout_height="@dimen/button_height"
            android:background="@drawable/rounded_button"
            android:text="@string/btn_register"
            android:textColor="@color/text_on_primary"
            android:textSize="@dimen/text_md"
            android:textStyle="bold"
            android:textAllCaps="false"
            android:layout_marginBottom="@dimen/spacing_lg" />

        <!-- Loading -->
        <ProgressBar
            android:id="@+id/progressBar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:indeterminateTint="@color/amber_primary"
            android:visibility="gone"
            android:layout_marginBottom="@dimen/spacing_lg" />

        <!-- Spacer -->
        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <!-- Login Link -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="@dimen/spacing_lg">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/register_has_account"
                android:textColor="@color/text_secondary"
                android:textSize="@dimen/text_sm" />

            <TextView
                android:id="@+id/tvLoginLink"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/register_login_link"
                android:textColor="@color/amber_primary"
                android:textSize="@dimen/text_sm"
                android:textStyle="bold" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>
